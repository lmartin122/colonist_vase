{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "npm run prisma:generate --workspace @colonist/server"
  },
  "deploy": {
    "startCommand": "npm run start --workspace @colonist/server",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
