# Client configuration. Copy to `.env` (Vite reads VITE_* at build/dev time).
# Local (vs-bots) play works even with everything below unset.

# Authoritative game server (Socket.IO + REST)
VITE_SERVER_URL=http://localhost:3001

# DEV ONLY: skip Auth0 and log in with just a name (pair with DEV_NO_AUTH=true
# on the server). Lets you play online locally with zero Auth0 setup.
VITE_DEV_LOGIN=true

# Auth0 SPA application (required only for ONLINE play)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
# Must match AUTH0_AUDIENCE on the server (the Auth0 API identifier)
VITE_AUTH0_AUDIENCE=https://colonist-vase/api
