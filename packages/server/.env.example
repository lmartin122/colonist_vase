# Server configuration. Copy to `.env` and fill in.

# HTTP/WebSocket port
PORT=3001

# Where the client is served from (CORS + Socket.IO origin)
CLIENT_ORIGIN=http://localhost:5173

# Auth0 (create an API in the Auth0 dashboard to get an audience)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://colonist-vase/api

# Postgres (Supabase → Connect → ORM → Prisma gives both of these).
# If empty, the server still runs but does NOT persist games/history (v1).
# DATABASE_URL = Transaction pooler (6543, pgbouncer). DIRECT_URL = Session
# pooler (5432), used only for migrations.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# DEV ONLY: skip Auth0 JWT verification and accept a "userId:name" token.
# Never enable in production.
DEV_NO_AUTH=false
