# Server configuration. Copy to `.env` and fill in.

# HTTP/WebSocket port
PORT=3001

# Where the client is served from (CORS + Socket.IO origin)
CLIENT_ORIGIN=http://localhost:5173

# Auth0 (create an API in the Auth0 dashboard to get an audience)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://colonist-vase/api

# Postgres connection string. If empty, the server still runs but does NOT
# persist games/history (best-effort persistence for v1).
DATABASE_URL=postgresql://user:pass@localhost:5432/colonist

# DEV ONLY: skip Auth0 JWT verification and accept a "userId:name" token.
# Never enable in production.
DEV_NO_AUTH=false
