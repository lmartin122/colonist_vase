// Prisma schema for profiles + match history.
// Generate the client with `npm run prisma:generate -w @colonist/server`.
// Create/apply migrations with `npm run prisma:migrate -w @colonist/server`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Supabase + Prisma: DATABASE_URL = Transaction pooler (6543, pgbouncer),
  // DIRECT_URL = Session pooler (5432) used for migrations. Copy both from
  // Supabase → Connect → ORM → Prisma.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String       @id @default(cuid())
  auth0Sub  String       @unique
  // Profile name from Auth0. For database (email/password) connections this IS
  // the email, which is why players need a username of their own.
  name      String
  // Player-chosen display name; null until they pick one. `usernameLower` is the
  // normalized form the unique index is on, so "Ada" and "ada" can't coexist.
  username      String?
  usernameLower String?  @unique
  createdAt DateTime     @default(now())
  wins      Game[]       @relation("winner")
  players   GamePlayer[]
}

model Game {
  id        String       @id @default(cuid())
  // Not unique on its own: a room keeps its code across rematches, so each game
  // in that room is identified by when it started.
  roomCode  String
  seed      Int
  layout    String
  mode      String       @default("classic")
  diceStats Json         @default("{}")
  winner    User?        @relation("winner", fields: [winnerId], references: [id])
  winnerId  String?
  startedAt DateTime
  endedAt   DateTime     @default(now())
  players   GamePlayer[]
  events    GameEvent[]

  @@unique([roomCode, startedAt])
}

model GamePlayer {
  id      String  @id @default(cuid())
  game    Game    @relation(fields: [gameId], references: [id])
  gameId  String
  user    User?   @relation(fields: [userId], references: [id])
  userId  String?
  seat    Int
  name    String
  isBot   Boolean
  finalVp Int
  stats              Json    @default("{}")
  longestRoadLength  Int     @default(0)
  longestRoadAward   Boolean @default(false)
  largestArmyAward   Boolean @default(false)
  abandoned          Boolean @default(false)
}

// TODO: full move history / replay. Every accepted action can be appended here
// (seed + ordered actions fully reproduce a game thanks to the deterministic
// engine). Left unpopulated in v1; wire it up in the action handler when ready.
model GameEvent {
  id     String @id @default(cuid())
  game   Game   @relation(fields: [gameId], references: [id])
  gameId String
  seq    Int
  action Json
}
